{
  "cli": {
    "version": ">= 20.5.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },

    "preview": {
      "developmentClient": false,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "env": {
          "ANDROID_NDK_VERSION": "26.1.10909105",
          "EXPO_PUBLIC_API_URL": "https://reward-app-ck2z.onrender.com"
        }
      }
    },

    "production": {
      "autoIncrement": true,
      "android": {
        "env": {
          "ANDROID_NDK_VERSION": "26.1.10909105"
        }
      }
    }
  },
  "submit": {
    "production": {}
  }
}